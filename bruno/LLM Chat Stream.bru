meta {
  name: LLM Chat Stream
  type: http
  seq: 3
}

post {
  url: http://127.0.0.1:8080/llm/chat/stream
  body: json
  auth: inherit
}

body:json {
  {
    "sessionId": "2",
    "message": "Tell me why Kotlin Coroutines better than Java Virtual Threads"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
